{
  "name": "@openbindings/graphql",
  "version": "0.1.0",
  "description": "OpenBindings GraphQL binding executor",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "openbindings",
    "graphql",
    "executor",
    "binding"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/openbindings/openbindings-ts.git",
    "directory": "packages/graphql"
  },
  "homepage": "https://openbindings.com",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@openbindings/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
